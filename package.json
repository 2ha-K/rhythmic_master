{
  "name": "rhythmic-master",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --config client/vite.config.ts --host 127.0.0.1 --port 5173",
    "dev:server": "tsx watch server/src/index.ts",
    "build": "tsc -p server/tsconfig.json && tsc -p client/tsconfig.json && vite build --config client/vite.config.ts",
    "test": "tsx server/src/rhythm.test.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "fastify": "^5.6.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "vexflow": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  }
}
